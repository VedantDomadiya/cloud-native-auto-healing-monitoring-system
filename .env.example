# =============================================================================
# Environment variables for the auto-healing monitoring stack
# Copy this file to .env and fill in real values. .env is gitignored.
# =============================================================================

# Bearer token the webhook requires in the Authorization header.
# Generate a real one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
WEBHOOK_TOKEN=replace-me-with-a-real-token

# Grafana admin credentials. Change before any non-local deployment.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Webhook configuration
WEBHOOK_PORT=5000
IDEMPOTENCY_WINDOW_SECONDS=30
AUDIT_LOG_PATH=/var/log/webhook/audit.log

# Default execution environment for remediations (docker | kubernetes)
DEFAULT_REMEDIATION_ENV=docker

# Kubernetes context to use when DEFAULT_REMEDIATION_ENV=kubernetes
KUBE_CONTEXT=minikube
