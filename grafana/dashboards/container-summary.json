{
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Process CPU rate as a fraction of one CPU core. Sourced from each service's own /metrics endpoint (prometheus_client auto-exports process_cpu_seconds_total). The S3 HighCPU alert fires when this exceeds 0.95 for 1 minute.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 15, "lineWidth": 2, "showPoints": "never", "spanNulls": false},
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 0.95}]},
          "unit": "percentunit",
          "min": 0
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "options": {
        "legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "rate(process_cpu_seconds_total{job=\"demo-services\"}[1m])",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "title": "Service CPU rate (S3 threshold = 0.95)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Resident memory of each demo service's Python process. The S2 HighMemory alert fires when this exceeds 230 MiB (~90% of the 256 MiB cgroup limit) for 30 seconds.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 15, "lineWidth": 2, "showPoints": "never", "spanNulls": false},
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 241591910}]},
          "unit": "bytes",
          "min": 0
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "options": {
        "legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "process_resident_memory_bytes{job=\"demo-services\"}",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "title": "Service resident memory (S2 threshold = 230 MiB)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Whether Prometheus can scrape each demo service's /metrics endpoint. Goes to 0 when the container is killed or unreachable; the S1 ContainerDown alert fires after this stays 0 for 30 seconds.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [
            {"options": {"0": {"color": "red", "text": "DOWN"}, "1": {"color": "green", "text": "UP"}}, "type": "value"}
          ],
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}
        }
      },
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 8},
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value_and_name"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "up{job=\"demo-services\"}",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "title": "Demo service liveness (Prometheus up{})",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Number of times each service has been restarted in the last 10 minutes (computed by counting changes in process_start_time_seconds). When the webhook auto-heals a service, this number jumps from 0 to 1 within a minute.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "continuous-RdYlGr"},
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 3}]},
          "unit": "short"
        }
      },
      "gridPos": {"h": 6, "w": 8, "x": 8, "y": 8},
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value_and_name"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "changes(process_start_time_seconds{job=\"demo-services\"}[10m])",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "title": "Restarts in last 10 min (auto-heal evidence)",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Count of currently firing alerts grouped by name. Green (0) is the normal state. During the live demo S1 will appear here briefly while the webhook performs the restart.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]},
          "unit": "short",
          "noValue": "0"
        }
      },
      "gridPos": {"h": 6, "w": 8, "x": 16, "y": 8},
      "id": 5,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value_and_name"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum by (alertname) (ALERTS{alertstate=\"firing\"}) or vector(0)",
          "legendFormat": "{{alertname}}",
          "refId": "A"
        }
      ],
      "title": "Alerts firing now",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Total HTTP requests per second handled by each demo service. The load-generator container holds a steady ~3 req/s baseline so panels never go empty.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 15, "lineWidth": 2, "showPoints": "never"},
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]},
          "unit": "reqps",
          "min": 0
        }
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 14},
      "id": 6,
      "options": {
        "legend": {"calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum by (service) (rate(http_requests_total[1m]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "title": "Demo service request rate (req/s)",
      "type": "timeseries"
    }
  ],
  "refresh": "5s",
